// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// USER / AUTH
// ================================
model User {
  id           String       @id @default(cuid())
  fullname     String       @map("full_name")
  email        String       @unique
  password     String
  role         Role         @default(customer)
  customerType CustomerType @default(new_customer) @map("customer_type")
  phone        String?
  address      String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  isActive     Boolean      @default(true) @map("is_active")

  orders Order[]

  @@index([email])
  @@index([fullname])
  @@index([email, fullname, phone])
  @@map("users")
}

enum Role {
  admin
  customer
}

enum CustomerType {
  new_customer
  reguler_customer
}

// ================================
// MENU & CATEGORY
// ================================
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  menus Menu[]

  @@map("categories")
}

model Menu {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  images      Json?
  isActive    Boolean  @default(true) @map("is_active")
  categoryId  String   @map("category_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category    Category     @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]

  @@map("menus")
}

// ================================
// STOCK ORDER (Capacity Control)
// ================================
model StockOrder {
  id           String   @id @default(cuid())
  eventDate    DateTime @map("event_date") @db.Date
  maxStock     Int      @map("max_stock")
  currentStock Int      @default(0) @map("current_stock")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")


  @@unique([eventDate])
  @@map("stock_orders")
}

// ================================
// ORDER
// ================================
model Order {
  id             String         @id @default(cuid())
  orderNumber    String         @unique @default(cuid()) @map("order_number")
  userId         String         @map("user_id")
  customerName   String         @map("customer_name")
  phone          String
  destination    String
  eventDate      DateTime       @map("event_date")
  note           String?
  code           String         @unique @default(cuid())
  deliveryMethod DeliveryMethod @default(dikirim) @map("delivery_method")
  orderStatus    OrderStatus    @default(pesanan_diterima) @map("order_status")
  shippingCost   Decimal        @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  totalPrice     Decimal        @map("total_price") @db.Decimal(10, 2)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  shipping   Shipping?

  @@map("orders")
}

enum DeliveryMethod {
  dikirim
  ambil_sendiri
}

enum OrderStatus {
  pesanan_diterima
  pesanan_diproses
  pesanan_selesai
  pesanan_dibatalkan
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String  @map("order_id")
  menuId   String  @map("menu_id")
  quantity Int
  subtotal Decimal @map("subtotal") @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu  Menu  @relation(fields: [menuId], references: [id])

  @@map("order_items")
}

// ================================
// SHIPPING
// ================================
model Shipping {
  id             String         @id @default(cuid())
  orderId        String         @unique @map("order_id")
  shippingStatus ShippingStatus @default(pesanan_disiapkan) @map("shipping_status")
  trackingNote   String?        @map("tracking_note")
  shippingCost   Decimal        @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  deliveredAt    DateTime?      @map("delivered_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shippings")
}

enum ShippingStatus {
  pesanan_disiapkan
  pesanan_dalam_proses_pengiriman
  pesanan_dibatalkan
  pesanan_selesai
}
